{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "chameleon/popular-rooms",
	"title": "Popular Rooms",
	"description": "Block that displays hotel's most popular rooms",
	"category": "chameleon",
	"supports": {
		"align": ["wide"]
	},
	"attributes": {
    "class": {
      "type": "string",
      "source": "attribute",
      "selector": "section",
      "attribute": "class"
    },
		"image_side": {
			"type": "boolean"
		},
		"popular_rooms": {
			"type": "array"
		}
	},
  "keywords": [
    "popular",
    "room"
  ],
	"editorScript": "file:./index.js",
  "style": "file:./popular-rooms-block.css",
	"render": "file:./render.php"
}